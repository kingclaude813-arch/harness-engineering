# ============================================================
# Harness Engineering - 환경 변수 설정
# 이 파일을 복사하여 .env 로 저장한 후 값을 채워주세요
# cp .env.example .env
# ============================================================

# ─── Claude API (메인 LLM) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6          # 기본 모델
CLAUDE_MAX_TOKENS=8192

# ─── Ollama / Gemma (로컬 경량 LLM) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b                   # gemma3:4b | gemma3:12b | gemma3:27b
GEMMA_TIMEOUT=60

# ─── GitHub ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-username
GITHUB_REPO_NAME=harness-engineering
GITHUB_ORG=                             # 비워두면 개인 계정 사용

# ─── Discord ─────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx
DISCORD_BOT_TOKEN=                      # 봇 기능 필요시 (선택)
DISCORD_CHANNEL_ID=                     # 봇 사용 시 채널 ID

# ─── LLM 라우팅 설정 ─────────────────────────────────────────
# 이 토큰 수 이상이면 Claude 사용, 미만이면 Gemma 사용
LLM_ROUTER_THRESHOLD=500
# 무조건 Claude를 쓸 작업 유형 (콤마 구분)
LLM_FORCE_CLAUDE_TASKS=architecture,security,complex_review

# ─── 프로젝트 설정 ───────────────────────────────────────────
PROJECT_NAME=harness-engineering
PROJECT_VERSION=0.1.0
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
